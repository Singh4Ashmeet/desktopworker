# User
USER_NAME=boss
PROJECTS_DIR=~/Projects

# LLM
ANTHROPIC_API_KEY=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
USE_LOCAL_LLM=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:72b
CLAUDE_MODEL=claude-opus-4-6

# Voice
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
TTS_SPEED=1.05
USE_OFFLINE_TTS=false

# Wake word
WAKE_WORD_SENSITIVITY=0.5
WAKE_WORD_MODEL=assets/wakeword/wake_up_sid.onnx
HOTKEY=ctrl+space

# Vision / awareness
ENABLE_VISION=true
SCREEN_CAPTURE_INTERVAL=20
ENABLE_PROACTIVE=true
ENABLE_FOCUS_BREAKS=false

# HUD
HUD_POSITION=bottom-right
HUD_OPACITY=0.92

# Security
SANDBOX_PATHS=["~"]
REQUIRE_CONFIRM_DELETE=true
ENABLE_UNDO_BUFFER=true
UNDO_BUFFER_MAX_MB=500

# Scheduler
ENABLE_MORNING_BRIEFING=false
BRIEFING_TIME=08:30

# Misc
LOG_LEVEL=INFO
SID_DIR=~/.sid
